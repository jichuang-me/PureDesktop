<Window x:Class="PureDesktop.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PureDesktop 说明" Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F9F9F9" CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown" Background="Transparent">
                <TextBlock Text="说明" FontSize="16" FontWeight="SemiBold" Margin="20,15" Foreground="#333333"/>
                <Button Content="✕" Width="40" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Click="OnCloseClick" Style="{StaticResource CloseButtonStyle}"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Instructions -->
                    <TextBlock Text="使用说明" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,10,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#555555" LineHeight="24">
                        1. 拖拽文件到格子中即可整理。支持跨屏移动与吸附。<LineBreak/>
                        2. 映射格子会自动同步文件夹内的文件。<LineBreak/>
                        3. 右键格子标题可进行快捷排序与分类。<LineBreak/>
                        4. 双击桌面空白处可显示/隐藏所有格子。
                    </TextBlock>

                    <Separator Margin="0,20" Background="#EEEEEE"/>

                    <!-- About -->
                    <TextBlock Text="关于 PureDesktop" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                         <Image Source="/Assets/app_icon.ico" Width="32" Height="32" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/> 
                         <!-- Note: Image might fail if asset not found, but it's optional -->
                         <StackPanel VerticalAlignment="Center">
                             <TextBlock Text="PureDesktop" FontSize="15" FontWeight="SemiBold" Foreground="#333333"/>
                             <TextBlock Text="v1.0.0 (Professional)" FontSize="12" Foreground="#888888"/>
                         </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Text="一款现代化、高性能、轻量级的 Windows 桌面整理工具。" 
                               TextWrapping="Wrap" Foreground="#666666" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="20,15" Background="#F5F5F5" CornerRadius="0,0,8,8">
                <TextBlock Text="版权所有 © 2026 jichuang 保留所有权利" HorizontalAlignment="Center" FontSize="12" Foreground="#999999"/>
            </Border>
        </Grid>
    </Border>
</Window>
